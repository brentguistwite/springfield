# Springfield project configuration.
# Copy to springfield.toml and adjust for your project.
#
# Runtime state is written to .springfield/ (gitignored).
# This file defines project-level Springfield config only.
# Conductor schedules live in .springfield/conductor/config.json,
# generated by `springfield conductor setup`.
#
# Safe defaults stay safe by default. Omit the [agents.*] blocks if you do not
# want Springfield to request agent-specific execution modes explicitly.

[project]
default_agent = "claude"

[agents.claude]
# Optional. Empty/omitted means Springfield will not pass an explicit
# Claude permission flag.
permission_mode = "bypassPermissions"

[agents.codex]
# Optional. Empty/omitted means Springfield will not pass explicit Codex
# sandbox or approval flags.
sandbox_mode = "workspace-write"
approval_policy = "on-request"

# [plans.release]
# agent = "codex"
