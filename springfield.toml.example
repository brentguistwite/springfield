# Springfield project configuration.
# Copy to springfield.toml and adjust for your project.
#
# Runtime state is written to .springfield/ (gitignored).
# This file defines project-level Springfield config only.
#
# Springfield v1 setup writes the recommended execution settings below by
# default. If you turn them off later, you must manage agent permissions
# yourself.

[project]
default_agent = "claude"
# agent_priority defines the order Springfield prefers agents in; the first entry is also the default.
agent_priority = ["claude", "codex"]

[agents.claude]
permission_mode = "bypassPermissions"

[agents.codex]
sandbox_mode = "danger-full-access"
approval_policy = "never"

# [plans.release]
# agent = "codex"
